---
import Layout from '../layouts/BlogPost.astro';
---

<Layout
	title="About Us"
	description="Meet Team Liberty"
	pubDate={new Date('March 08 2026')}
	heroImage="/me.jpg"
>
<body id="top">
  <a class="skip-link" href="#main-content">Skip to main content</a>
  <header class="site-header py-4">
    <div class="container site-container">         
      <p class="site-title">
        <a class="text-center" href="index.html">The Liberty Articulator</a>
      </p>
      <p class="site-tagline text-center">
        Investigating under the microscope of liberty.<br>
        Analyzing through the telescope of history.
      </p>               
    </div>
    <button type="button" class="btn btn-primary btn-lg btn-block" style="color: orange;" href="subscribe.html">Subscribe</button>    
  </header>
<body id="top">
  <a class="skip-link" href="#main-content">Skip to main content</a>
  <nav class="site-nav py-2" aria-label="Primary navigation">
      <ul class="nav d-flex justify-content-center">
        <li class="nav-item"><a class="nav-link" href="index.astro">Home</a></li>       
        <li class="nav-item"><a class="nav-link" href="historysheroes.html">History's Heroes</a></li>
        <li class="nav-item"><a class="nav-link" href="about.astro">Staff</a></li>
        <li class="nav-item"><a class="nav-link" href="contact.astro">Contact</a></li>
        <li class="nav-item"><a class="nav-link" href="subscribe.html">Subscribe</a></li>       
      </ul>
  </nav>
  <main id="main-content" class="container site-container">
    <article class="article-page">
      <div class="article-content">       
        <h3>
          About Us
        </h3>      
      <div class="container mt-3">
        <h2>This is Team Liberty!</h2>
        <p>Lamont Michael Kimberlin: Chief Editor</p>
        <div class="card" style="width:400px">
          <img class="card-img-top" src="../bootstrap4/img_avatar1.png" alt="Card image" style="width:100%">
            <div class="card-body">
              <h4 class="card-title">Lamont Michael Kimberlin</h4>
              <p class="card-text">Lamont Kimberlin is Founder, Sole Proprietor, and Chief Editor of The Liberty Articulator.</p>
              <a href="lamontkimberlin.html" class="btn btn-primary">See Profile</a>
           </div>
         </div>
         <br>
      <div class="container mt-3">
        <p>Noah Kimberlin: Lead Editor</p>
        <div class="card" style="width:400px">
          <img class="card-img-top" src="../bootstrap4/img_avatar1.png" alt="Card image" style="width:100%">
            <div class="card-body">
              <h4 class="card-title">Noah Kimberlin</h4>
              <p class="card-text">Noah Kimberlin is the Lead Editor of The Liberty Articulator.</p>
              <p class="card-text">He is also the founder and Chief Editor of The Liberty Articulator's      .</p>
              <a href="noahkimberlin.html" class="btn btn-primary">See Profile</a>
            </div>
        </div>
         <br>          
         <p></p>
         <div class="card" style="width:400px">
           <div class="card-body">
             <h4 class="card-title">Petra Morris</h4>
             <p class="card-text">Petra Morris is a Contributing Editor of The Liberty Emporium.</p>
             <p class="card-text">She is also the founder and Chief Editor of The Liberty Emporium's Butthead Division.</p>
             <a href="petramorris.html" class="btn btn-primary">See Profile</a>
           </div>
             <img class="card-img-bottom" src="../bootstrap4/img_avatar6.png" alt="Card image" style="width:100%">
         </div>                                          
      </div>              
    </article>
  </main>
  <footer class="site-footer">
    <div class="container site-container">
      <address>
        Written by<br>
        Lamont Michael Kimberlin<br>
        The Liberty Articulator<br>
        United States<br>
        Contact via email at:<br>
        <a href="mailto:libertymaster@thelibertyarticulator.com">libertymaster@thelibertyarticulator.com</a>
      </address>
      <img
        src="images/me.png"
        alt="Portrait of Lamont Kimberlin"
        class="footer-portrait"
        loading="lazy"
      >
      <p>
        And don't forget to...<br>
        Embrace your liberty!
      </p>
      <div class="footer-links">
        <a href="#top">Back to top</a>
        <a href="index.html">Back to Home page</a>
      </div>
    </div>
  </footer>
</body>
</html>
</Layout>
