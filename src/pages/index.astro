---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
{% extends "base.html" %}

{% block title %}{{ site_name }} | News, history, and public argument{% endblock %}
{% block meta_description %}{{ site_tagline }}{% endblock %}

{% block content %}
<section class="hero">
  <p class="eyebrow">Independent publication</p>
  <h2>Investigating under the microscope of liberty.</h2>
  <h2>Analyzing through the telescope of history.</h2>
  <p class="dek">{{ site_tagline }} Read current reporting alongside durable essays, biographies, primary sources, and scholarly works.</p> 
  <div class="hero-actions">
    <a class="button" href="{% url 'articles:list' %}">Read the latest</a>
    <a class="text-link" href="{% url 'newsletter:subscribe' %}">Join the newsletter</a>
  </div>
</section>

{% if featured_articles %}
<section class="section-block" aria-labelledby="featured-heading">
  <div class="section-heading">
    <p class="eyebrow">Selected</p>
    <h2 id="featured-heading">Featured work</h2>
  </div>
  <div class="feature-grid">
    {% for article in featured_articles %}
      <article class="feature-card">
        {% if article.featured_image %}<img src="{{ article.featured_image.url }}" alt="{{ article.featured_image_alt }}">{% endif %}
        <p class="article-meta">{{ article.get_content_type_display }} · {{ article.published_at|date:"F j, Y" }}</p>
        <h3><a href="{{ article.get_absolute_url }}">{{ article.title }}</a></h3>
        <p>{{ article.summary }}</p>
      </article>
    {% endfor %}
  </div>
</section>
{% endif %}

{% if featured_series %}
<section class="series-promo" aria-labelledby="series-promo-heading">
  <div>
    <p class="article-series">{{ site_name }} presents</p>
    <h2 id="series-promo-heading"><a href="{{ featured_series.get_absolute_url }}">{{ featured_series.title }}</a></h2>
    {% if featured_series.tagline %}<p class="lead">{{ featured_series.tagline }}</p>{% endif %}
    {% if featured_series.description %}<p>{{ featured_series.description|truncatewords:60 }}</p>{% endif %}
    <a class="text-link" href="{{ featured_series.get_absolute_url }}">Explore the series</a>
  </div>
  {% if featured_series.hero_image %}<img src="{{ featured_series.hero_image.url }}" alt="{{ featured_series.hero_image_alt }}">{% endif %}
</section>
{% endif %}

<section class="section-block" aria-labelledby="latest-heading">
  <div class="section-heading section-heading-row">
    <div>
      <p class="eyebrow">Archive</p>
      <h2 id="latest-heading">Latest articles</h2>
    </div>
    <a class="text-link" href="{% url 'articles:list' %}">View all</a>
  </div>
  <div class="article-list">
    {% for article in latest_articles %}
      {% include "articles/_article_row.html" with article=article %}
    {% empty %}
      <div class="empty-state">
        <h3>No published articles yet</h3>
        <p>Create an author, section, or series and publish the first article in the Django administration site.</p>
      </div>
    {% endfor %}
  </div>
</section>

{% if latest_papers %}
<section class="section-block" aria-labelledby="papers-heading">
  <div class="section-heading section-heading-row">
    <div>
      <p class="eyebrow">Research</p>
      <h2 id="papers-heading">Papers and source documents</h2>
    </div>
    <a class="text-link" href="{% url 'articles:list' %}?type=paper">View papers</a>
  </div>
  <div class="article-list">
    {% for article in latest_papers %}{% include "articles/_article_row.html" with article=article %}{% endfor %}
  </div>
</section>
{% endif %}

<section class="newsletter-band">
  <div>
    <p class="eyebrow">Newsletter</p>
    <h2>Receive the latest work by email.</h2>
  </div>
  <a class="button button-light" href="{% url 'newsletter:subscribe' %}">Subscribe</a>
</section>
{% endblock %}
